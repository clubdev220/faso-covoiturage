rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== HELPERS =====
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isDriver() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'driver';
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isValidUserData() {
      let data = request.resource.data;
      return data.keys().hasAll(['phone', 'displayName', 'role']) &&
        data.phone is string &&
        data.displayName is string &&
        data.role in ['passenger', 'driver', 'admin', 'agent_relay'];
    }
    
    function isValidTripData() {
      let data = request.resource.data;
      return data.keys().hasAll([
        'driverId', 'origin', 'originCity', 'destination', 
        'destinationCity', 'departureDate', 'departureTime',
        'totalSeats', 'pricePerSeat', 'vehicleInfo'
      ]) &&
        data.driverId is string &&
        data.totalSeats is int &&
        data.pricePerSeat is int &&
        data.availableSeats is int;
    }
    
    // ===== USERS =====
    
    match /users/{userId} {
      // Anyone can read user profiles (for reviews, trip info)
      allow read: if true;
      
      // Users can only write their own profile
      allow write: if isOwner(userId);
      
      // Admin can update any user role
      allow update: if isAdmin() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'kycStatus', 'rating', 'reviewCount', 'updatedAt']);
    }
    
    // ===== TRIPS =====
    
    match /trips/{tripId} {
      // Anyone can read active trips
      allow read: if resource.data.status == 'active' || isAuthenticated();
      
      // Only drivers or admins can create trips
      allow create: if isAuthenticated() && 
        isDriver() && 
        request.resource.data.driverId == request.auth.uid &&
        isValidTripData();
      
      // Only trip owner (driver) or admin can update
      allow update: if isAuthenticated() && 
        (resource.data.driverId == request.auth.uid || isAdmin()) &&
        request.resource.data.driverId == resource.data.driverId; // Can't change driverId
      
      // Only owner or admin can delete
      allow delete: if isAuthenticated() && 
        (resource.data.driverId == request.auth.uid || isAdmin());
    }
    
    // ===== BOOKINGS =====
    
    match /bookings/{bookingId} {
      // Passengers can read their own bookings
      // Drivers can read bookings for their trips
      allow read: if isAuthenticated() && 
        (resource.data.passengerId == request.auth.uid || 
         (exists(/databases/$(database)/documents/trips/$(resource.data.tripId)) &&
          get(/databases/$(database)/documents/trips/$(resource.data.tripId)).data.driverId == request.auth.uid) ||
         isAdmin());
      
      // Passengers can create bookings
      allow create: if isAuthenticated() && 
        request.resource.data.passengerId == request.auth.uid &&
        request.resource.data.keys().hasAll(['tripId', 'seats', 'totalAmount', 'status']);
      
      // Drivers can update booking status for their trips
      // Admin can update any booking
      allow update: if isAuthenticated() && 
        (isAdmin() ||
         get(/databases/$(database)/documents/trips/$(resource.data.tripId)).data.driverId == request.auth.uid);
    }
    
    // ===== PAYMENTS =====
    
    match /payments/{paymentId} {
      // Payment is only accessible by the passenger who made the booking or admin
      allow read: if isAuthenticated() && 
        (resource.data.keys().hasAny(['bookingId']) &&
         exists(/databases/$(database)/documents/bookings/$(resource.data.bookingId)) &&
         get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.passengerId == request.auth.uid
        ) || isAdmin();
      
      // System creates payments (via Cloud Functions or admin)
      allow create: if isAuthenticated() && 
        (request.resource.data.keys().hasAll(['bookingId', 'amount', 'method', 'status']) ||
         isAdmin());
      
      // Only admin or system can update payment status
      allow update: if isAdmin();
    }
    
    // ===== REVIEWS =====
    
    match /reviews/{reviewId} {
      // Anyone can read reviews (to see ratings)
      allow read: if true;
      
      // Authenticated users can create reviews
      allow create: if isAuthenticated() && 
        request.resource.data.reviewerId == request.auth.uid &&
        request.resource.data.keys().hasAll(['tripId', 'reviewedId', 'rating', 'type']) &&
        request.resource.data.rating >= 1 && 
        request.resource.data.rating <= 5;
      
      // Can't update or delete reviews (immutable)
      allow update, delete: if false;
    }
    
    // ===== NOTIFICATIONS =====
    
    match /notifications/{notifId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      
      // System creates notifications (via Cloud Functions)
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      
      // Users can mark notifications as read
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
    }
    
    // ===== REPORTS =====
    
    match /reports/{reportId} {
      // Admin can read all reports
      allow read: if isAdmin();
      
      // Authenticated users can create reports
      allow create: if isAuthenticated() && 
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.keys().hasAll(['reportedUserId', 'reason', 'description']);
      
      // Admin can update report status
      allow update: if isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'resolvedAt']);
    }
  }
}